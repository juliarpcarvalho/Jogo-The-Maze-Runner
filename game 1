    15: "VERMELHO", 16: "VERDE", 17: "BRANCO", 18: "AMARELO", 19: "BRANCO", 
    20: "VERMELHO", 21: "VERDE", 22: "BRANCO", 23: "AZUL", 24: "VERMELHO", 
    25: "AMARELO", 26: "VERDE", 27: "FIM"
}
jog1={'vida':10, 'posicao':0, 'pos':posicoes[0], 'cor':'verde'}
jog2={'vida':10, 'posicao':0, 'pos':posicoes[0], 'cor':'roxo'}

jogadores_presos=[0,0]

jogadores=[jog1, jog2]
turno=0
y=0

jogo_iniciado=False
