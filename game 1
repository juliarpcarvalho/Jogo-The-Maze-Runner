running=True

while running:
    screen.fill((255,255,255))
    pygame.draw.rect(screen, (0, 0, 0), (20, 50, 80, 80))#preto
    pygame.draw.rect(screen, (225,225,225), (100, 50, 80, 80))#branco
    pygame.draw.rect(screen, (225, 0, 0), (180, 50, 80, 80))#vermelho
